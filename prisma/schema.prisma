generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FOUNDER
  INVESTOR
  COMMUNITY
  ADMIN
}

enum StartupStage {
  IDEATION
  VALIDATION
  EARLY_TRACTION
  GROWTH
  SCALING
}

enum StartupStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum VerificationLevel {
  NONE
  COMMUNITY
  EXPERT
  FULL
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum ArticleCategory {
  GUIDE
  SCHEME
  REPORT
}

// ─── NextAuth Required Models ────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Application Models ─────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  hashedPassword    String?
  fullName          String
  avatarUrl         String?
  role              UserRole  @default(COMMUNITY)
  phone             String?
  linkedinUrl       String?
  organization      String?
  bio               String?
  preferredLanguage String    @default("en")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  startups              Startup[]              @relation("FounderStartups")
  upvotes               Upvote[]
  comments              Comment[]
  reviewedVerifications VerificationRequest[]  @relation("Reviewer")
  knowledgeArticles     KnowledgeArticle[]
  investorProfile       InvestorProfile?

  @@map("users")
}

model Startup {
  id                String            @id @default(cuid())
  founderId         String
  name              String
  slug              String            @unique
  tagline           String
  description       String?           @db.Text
  logoUrl           String?
  bannerUrl         String?
  websiteUrl        String?
  foundedYear       Int?
  stage             StartupStage      @default(IDEATION)
  techCategory      String
  subCategories     Json?
  state             String?
  district          String?
  teamSize          Int?
  fundingStatus     String?
  fundingAmount     String?
  problemStatement  String?           @db.Text
  solution          String?           @db.Text
  businessModel     String?           @db.Text
  impactMetrics     Json?
  fieldTrialData    Json?
  pitchDeckUrl      String?
  demoVideoUrl      String?
  galleryUrls       Json?
  socialLinks       Json?
  status            StartupStatus     @default(DRAFT)
  verificationLevel VerificationLevel @default(NONE)
  upvoteCount       Int               @default(0)
  viewCount         Int               @default(0)
  isFeatured        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  founder              User                  @relation("FounderStartups", fields: [founderId], references: [id])
  teamMembers          TeamMember[]
  upvotes              Upvote[]
  comments             Comment[]
  verificationRequests VerificationRequest[]
  jobs                 Job[]

  @@index([techCategory])
  @@index([stage])
  @@index([status])
  @@index([verificationLevel])
  @@index([upvoteCount(sort: Desc)])
  @@index([founderId])
  @@map("startups")
}

model TeamMember {
  id          String  @id @default(cuid())
  startupId   String
  name        String
  role        String
  linkedinUrl String?
  avatarUrl   String?

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

model Upvote {
  id        String   @id @default(cuid())
  userId    String
  startupId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([userId, startupId])
  @@index([startupId])
  @@map("upvotes")
}

model VerificationRequest {
  id           String    @id @default(cuid())
  startupId    String
  status       String    @default("pending")
  reviewerId   String?
  reviewNotes  String?   @db.Text
  evidenceUrls Json?
  submittedAt  DateTime  @default(now())
  reviewedAt   DateTime?

  startup  Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("Reviewer", fields: [reviewerId], references: [id])

  @@map("verification_requests")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  startupId String
  content   String   @db.Text
  parentId  String?
  createdAt DateTime @default(now())

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startup Startup   @relation(fields: [startupId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([startupId])
  @@map("comments")
}

model KnowledgeArticle {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  content     String          @db.Text
  excerpt     String?
  category    ArticleCategory
  authorId    String
  tags        Json?
  isPublished Boolean         @default(false)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())

  author User @relation(fields: [authorId], references: [id])

  @@index([category])
  @@index([isPublished])
  @@map("knowledge_articles")
}

model Job {
  id             String    @id @default(cuid())
  startupId      String
  title          String
  description    String    @db.Text
  location       String
  type           JobType
  salaryRange    String?
  requirements   Json?
  applicationUrl String?
  isActive       Boolean   @default(true)
  postedAt       DateTime  @default(now())
  expiresAt      DateTime?

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
  @@index([postedAt(sort: Desc)])
  @@map("jobs")
}

model InvestorProfile {
  id                  String  @id @default(cuid())
  userId              String  @unique
  firmName            String?
  thesis              String? @db.Text
  checkSizeMin        Int?
  checkSizeMax        Int?
  preferredStages     Json?
  preferredCategories Json?
  portfolioCount      Int?    @default(0)
  websiteUrl          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investor_profiles")
}
