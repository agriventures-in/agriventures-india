generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FOUNDER
  INVESTOR
  COMMUNITY
  ADMIN
}

enum StartupStage {
  IDEATION
  VALIDATION
  EARLY_TRACTION
  GROWTH
  SCALING
}

enum StartupStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum VerificationLevel {
  NONE
  COMMUNITY
  EXPERT
  FULL
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum ArticleCategory {
  GUIDE
  SCHEME
  REPORT
}

enum IntroStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ─── NextAuth Required Models ────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Application Models ─────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  hashedPassword    String?
  fullName          String
  avatarUrl         String?
  role              UserRole  @default(COMMUNITY)
  phone             String?
  linkedinUrl       String?
  organization      String?
  bio               String?
  preferredLanguage String    @default("en")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts              Account[]
  sessions              Session[]
  startups              Startup[]              @relation("FounderStartups")
  upvotes               Upvote[]
  comments              Comment[]
  reviewedVerifications VerificationRequest[]  @relation("Reviewer")
  knowledgeArticles     KnowledgeArticle[]
  investorProfile       InvestorProfile?
  notifications         Notification[]
  introRequestsSent     IntroRequest[]    @relation("IntroFrom")
  introRequestsReceived IntroRequest[]    @relation("IntroTo")
  coFounderProfile      CoFounderProfile?
  campusScout           CampusScout?

  @@map("users")
}

model Startup {
  id                String            @id @default(cuid())
  founderId         String
  name              String
  slug              String            @unique
  tagline           String
  description       String?           @db.Text
  logoUrl           String?
  bannerUrl         String?
  websiteUrl        String?
  foundedYear       Int?
  stage             StartupStage      @default(IDEATION)
  techCategory      String
  subCategories     Json?
  state             String?
  district          String?
  teamSize          Int?
  fundingStatus     String?
  fundingAmount     String?
  problemStatement  String?           @db.Text
  solution          String?           @db.Text
  businessModel     String?           @db.Text
  impactMetrics     Json?
  fieldTrialData    Json?
  pitchDeckUrl      String?
  demoVideoUrl      String?
  galleryUrls       Json?
  socialLinks       Json?
  status            StartupStatus     @default(DRAFT)
  verificationLevel VerificationLevel @default(NONE)
  upvoteCount       Int               @default(0)
  viewCount         Int               @default(0)
  isFeatured        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  founder              User                  @relation("FounderStartups", fields: [founderId], references: [id])
  teamMembers          TeamMember[]
  upvotes              Upvote[]
  comments             Comment[]
  verificationRequests VerificationRequest[]
  jobs                 Job[]
  introRequests        IntroRequest[]
  views                StartupView[]
  coFounderProfiles    CoFounderProfile[]

  @@index([techCategory])
  @@index([stage])
  @@index([status])
  @@index([verificationLevel])
  @@index([upvoteCount(sort: Desc)])
  @@index([founderId])
  @@map("startups")
}

model TeamMember {
  id          String  @id @default(cuid())
  startupId   String
  name        String
  role        String
  linkedinUrl String?
  avatarUrl   String?

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

model Upvote {
  id        String   @id @default(cuid())
  userId    String
  startupId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([userId, startupId])
  @@index([startupId])
  @@map("upvotes")
}

model VerificationRequest {
  id           String    @id @default(cuid())
  startupId    String
  status       String    @default("pending")
  reviewerId   String?
  reviewNotes  String?   @db.Text
  evidenceUrls Json?
  submittedAt  DateTime  @default(now())
  reviewedAt   DateTime?

  startup  Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("Reviewer", fields: [reviewerId], references: [id])

  @@map("verification_requests")
}

model Comment {
  id        String    @id @default(cuid())
  userId    String
  startupId String
  content   String    @db.Text
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startup Startup   @relation(fields: [startupId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([startupId])
  @@map("comments")
}

model KnowledgeArticle {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  content     String          @db.Text
  excerpt     String?
  category    ArticleCategory
  authorId    String
  tags        Json?
  isPublished Boolean         @default(false)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())

  author User @relation(fields: [authorId], references: [id])

  @@index([category])
  @@index([isPublished])
  @@map("knowledge_articles")
}

model Job {
  id             String    @id @default(cuid())
  startupId      String
  title          String
  description    String    @db.Text
  location       String
  type           JobType
  salaryRange    String?
  requirements   Json?
  applicationUrl String?
  isActive       Boolean   @default(true)
  postedAt       DateTime  @default(now())
  expiresAt      DateTime?

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId])
  @@index([postedAt(sort: Desc)])
  @@map("jobs")
}

model InvestorProfile {
  id                  String  @id @default(cuid())
  userId              String  @unique
  firmName            String?
  thesis              String? @db.Text
  checkSizeMin        Int?
  checkSizeMax        Int?
  preferredStages     Json?
  preferredCategories Json?
  portfolioCount      Int?    @default(0)
  websiteUrl          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("investor_profiles")
}

// ─── Phase 2 Models ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model IntroRequest {
  id           String      @id @default(cuid())
  fromUserId   String
  toUserId     String
  startupId    String
  message      String      @db.Text
  status       IntroStatus @default(PENDING)
  responseNote String?     @db.Text
  createdAt    DateTime    @default(now())
  respondedAt  DateTime?

  fromUser User    @relation("IntroFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("IntroTo", fields: [toUserId], references: [id], onDelete: Cascade)
  startup  Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, startupId])
  @@index([toUserId, status])
  @@map("intro_requests")
}

model StartupView {
  id        String   @id @default(cuid())
  startupId String
  userId    String?
  createdAt DateTime @default(now())

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@index([startupId, createdAt])
  @@map("startup_views")
}

// ─── Co-Founder Matchmaker ─────────────────────────────────────

enum Commitment {
  FULL_TIME
  PART_TIME
  ADVISORY
}

model CoFounderProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  title           String       // e.g. "Looking for a Technical Co-Founder"
  bio             String       @db.Text // What you bring to the table
  lookingFor      String       @db.Text // What you want in a co-founder
  skills          Json         // Your skills: string[]
  desiredSkills   Json         // Skills you want: string[]
  category        String       // AgriTech category
  preferredStage  StartupStage @default(IDEATION)
  state           String?      // Indian state
  commitment      Commitment   @default(FULL_TIME)
  hasStartup      Boolean      @default(false)
  startupId       String?      // Optional link to existing startup
  linkedinUrl     String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startup Startup? @relation(fields: [startupId], references: [id])

  @@index([category])
  @@index([isActive])
  @@index([preferredStage])
  @@map("co_founder_profiles")
}

// ─── Campus Scout Program ──────────────────────────────────────

enum ScoutStatus {
  APPLIED
  ACTIVE
  INACTIVE
}

model CampusScout {
  id            String      @id @default(cuid())
  userId        String      @unique
  collegeName   String
  state         String
  district      String?
  course        String      // e.g. "B.Tech Agriculture"
  graduationYear Int
  why           String      @db.Text  // Why do you want to be a scout?
  linkedinUrl   String?
  status        ScoutStatus @default(APPLIED)
  startupsReferred Int      @default(0)
  points        Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([state])
  @@index([points(sort: Desc)])
  @@map("campus_scouts")
}
